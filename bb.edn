{:paths ["src"]
 :deps {org.babashka/cli {:mvn/version "0.8.67"}
        cheshire/cheshire {:mvn/version "6.2.0"}
        ;; clojure-mcp-light transitive deps
        parinferish/parinferish {:mvn/version "0.8.0"}
        dev.weavejester/cljfmt {:mvn/version "0.16.4"}
        ;; clojure-mcp-light — upstream delimiter repair + nREPL eval
        io.github.bhauman/clojure-mcp-light {:git/tag "v0.2.1"
                                             :git/sha "31e19702feea79e4b98c8d89d9df6e297cc740bf"}
        ;; babashka/fs — glob and filesystem utilities
        babashka/fs {:mvn/version "0.5.32"}
        ;; modex-bb — MCP server framework
        io.github.hive-agi/modex-bb {:git/tag "v0.1.2"
                                     :git/sha "b12e8fc0db65129d2423595286e18c3f515ab8f5"}}
 :tasks
 {server {:doc "Start the basic-tools MCP server (babashka)"
          :task (exec 'basic-tools-mcp.server/-main)}}}
